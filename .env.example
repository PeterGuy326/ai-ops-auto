# ====== 数据库 ======
# SQLite (默认开发) 或 PostgreSQL
DATABASE_URL=sqlite:///./data/ai_ops.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ai_ops

# ====== 凭证加密 ======
# 用于加密存储 cookie/token，必须保密；生成方法：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ====== LLM ======
# 至少配一个 driver。默认 driver 由 LLM_DEFAULT 控制。
LLM_DEFAULT=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# ====== 外部工具路径（submodule 方式）======
EXTERNAL_SAU_PATH=./external/social-auto-upload
EXTERNAL_MPT_PATH=./external/MoneyPrinterTurbo

# ====== 外部工具 URL（独立服务方式）======
# 优先使用 URL；URL 留空则 fallback 到 PATH + subprocess
EXTERNAL_SAU_URL=
EXTERNAL_MPT_URL=http://localhost:8080
EXTERNAL_XHS_MCP_URL=

# MPT 的 x-api-key（与 MPT config.toml 的 app.api_key 一致；为空 = MPT 未启用鉴权）
MPT_API_KEY=

# ====== 调度 ======
SCHEDULER_BACKEND=apscheduler
# SCHEDULER_BACKEND=celery
# CELERY_BROKER_URL=redis://localhost:6379/0

# ====== 风控 ======
# 单账号单平台每日发布上限
RATE_LIMIT_PER_DAY=5
# 同账号查重相似度阈值（0-1，越大越严）
DEDUP_SIMHASH_THRESHOLD=0.85

# ====== API ======
API_HOST=127.0.0.1
API_PORT=8000
API_LOG_LEVEL=info
