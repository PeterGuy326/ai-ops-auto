# ====== 数据库 ======
# SQLite (默认开发) 或 PostgreSQL
DATABASE_URL=sqlite:///./data/ai_ops.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ai_ops

# ====== 凭证加密 ======
# 用于加密存储 cookie/token，必须保密；生成方法：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ====== LLM ======
# 至少配一个 driver。默认 driver 由 LLM_DEFAULT 控制。
LLM_DEFAULT=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# ====== 外部工具路径（submodule 方式）======
EXTERNAL_SAU_PATH=./external/social-auto-upload
EXTERNAL_MPT_PATH=./external/MoneyPrinterTurbo

# ====== FunClip · 智能视频剪辑（ASR + 文字稿切片）======
# clone: git clone https://github.com/modelscope/FunClip external/FunClip
# venv:  cd external/FunClip && python -m venv .venv && .venv/bin/pip install -r requirements.txt
# 详见 docs/funclip-setup.md
FUNCLIP_PATH=./external/FunClip
FUNCLIP_PYTHON=./external/FunClip/.venv/bin/python
FUNCLIP_TIMEOUT_SECONDS=1800
FUNCLIP_OUTPUT_ROOT=./data/clips

# ====== 外部工具 URL（独立服务方式）======
# 优先使用 URL；URL 留空则 fallback 到 PATH + subprocess
EXTERNAL_SAU_URL=
EXTERNAL_MPT_URL=http://localhost:8080
EXTERNAL_XHS_MCP_URL=

# MPT 的 x-api-key（与 MPT config.toml 的 app.api_key 一致；为空 = MPT 未启用鉴权）
MPT_API_KEY=

# ====== 调度 ======
SCHEDULER_BACKEND=apscheduler
# SCHEDULER_BACKEND=celery
# CELERY_BROKER_URL=redis://localhost:6379/0

# ====== 风控 ======
# 单账号单平台每日发布上限
RATE_LIMIT_PER_DAY=5
# 同账号查重相似度阈值（0-1，越大越严）
DEDUP_SIMHASH_THRESHOLD=0.85

# ====== 反风控（小红书首选 camoufox） ======
# 浏览器引擎：playwright_chromium / playwright_chrome_channel / patchright / camoufox
# 切到 camoufox 时，XhsCamoufoxPublisher 自动成为小红书主链路
BROWSER_ENGINE=playwright_chrome_channel
# 是否无头（高风控平台建议 False）
BROWSER_HEADLESS=False
# 全局兜底代理（生产环境强烈建议每账号单独配 profile.proxy）
BROWSER_PROXY=
# 同账号最小发布间隔（秒），默认 4h
PUBLISH_MIN_INTERVAL_SECONDS=14400
# 单账号每日发布上限
PUBLISH_MAX_PER_DAY=2
# 养号期天数（注册后多少天内禁发）
NURTURE_DAYS=7
# 发布时间打散窗口（秒）— 计划时间 + random(0, N)，规避"机器规律"
PUBLISH_JITTER_SECONDS=600
# 文案是否经反 AI 检测 humanize
XHS_HUMANIZE_ENABLED=True

# ====== API ======
API_HOST=127.0.0.1
API_PORT=8000
API_LOG_LEVEL=info
